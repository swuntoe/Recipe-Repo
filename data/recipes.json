  {
    "name": "法式千層可麗餅蛋糕",
    "description": "參考「矽谷美味人妻」的食譜，據說是Lady M風味。",
    "servings": 8,
    "prepTime": 30,
    "cookTime": 60,
    "ingredients": [
      {
        "group": "餅皮麵糊",
        "items": [
          {
            "name": "無鹽奶油",
            "amount": 80,
            "unit": "g"
          },
          {
            "name": "牛奶",
            "amount": 3,
            "unit": "cup"
          },
          {
