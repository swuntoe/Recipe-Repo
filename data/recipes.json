            "unit": "tbsp"
          },
            {
                "name": "鹽",
                "amount": 0.125,
                "unit": "tsp"
            }
        ]
      },
      {
        "group": "卡士達醬",
        "items": [
          {
            "name": "蛋",
            "amount": 1,
            "unit": "個"
          },
          {
            "name": "麵粉",
            "amount": 1,
            "unit": "tbsp"
          },
          {
            "name": "玉米粉",
            "amount": 1,
            "unit": "tbsp"
          },
          {
            "name": "砂糖",
            "amount": 2,
            "unit": "tbsp"
          },
          {
            "name": "香草精",
            "amount": 1,
            "unit": "tsp"
          },
            {
                "name": "牛奶",
                "amount": 1,
                "unit": "cup"
            }
        ]
      },
      {
        "group": "打發鮮奶油",
        "items": [
          {
            "name": "無糖動物性全脂鮮奶油",
            "amount": 2,
            "unit": "杯"
          },
          {
            "name": "糖",
            "amount": 1,
            "unit": "tbsp"
          }
        ]
      }
    ],
    "instructions": [
      {
        "group": "製作餅皮麵糊",
        "steps": [
          "加熱融化無鹽奶油，可以用低功率微波加熱20秒。小心不要微波太久，以免整塊奶油炸開。",
          "加入麵粉、加入麵粉、糖、鹽到融化奶油中，攪拌均勻。",
          "加入牛奶，繼續攪拌。有點顆粒也沒關係。",
          "冷藏至少4小時，最好隔夜。這樣沒有攪拌開的顆粒就會自己慢慢化開了。"
        ]
      },
      {
        "group": "煎餅皮",
        "steps": [
          "拿24cm的平底鍋，開中小火，倒入大約半湯勺的麵糊。用煎可麗餅專用的工具（或是鍋鏟）把麵糊攤平，形成薄薄的一層。",
          "拿另一個比較大28cm的平底鍋，也開中小火在旁邊預熱。",
          "不用煎到太乾太熟，表面有點濕潤就可以準備翻面了。",
          "因為有兩個鍋子，可以不用在同一個鍋子上翻面。直接把小的鍋子倒蓋到大的鍋子上，餅皮就翻過去了。",
          "翻在大鍋子的餅皮很難控制到完美的翻面，這也沒關係，先放著讓它加熱。",
          "翻面後立刻在小鍋子上倒上新一勺的麵糊，攤平新的麵糊後，就可以來處理剛剛翻到大鍋子的上一片餅皮了。",
          "儘量把翻過去的餅皮攤平，餅皮破掉也沒關係，充分加熱避免雞蛋沒熟比較重要。在裡面的餅皮最後組裝起來就看不出來了。",
          "差不多到小鍋子的餅皮要翻面時，就可以把大鍋飯過面的餅皮拿起來了。理想狀態是又薄又嫩的餅皮，太厚太熟口感會沒那麼好。",
          "第一片跟最後一片煎厚一點，最後組裝起來比較漂亮。"
        ]
      },
      {
        "group": "打發蛋白",
        "steps": [
          "蛋白打至硬性發泡",
          "分次加入馬斯卡彭混合物中輕輕攪拌"
        ]
      },
      {
        "group": "組裝",
        "steps": [
          "手指餅乾快速浸入咖啡浸液",
          "排列在模具底層",
          "鋪上一層馬斯卡彭奶醬",
          "重複前面步驟，最後以奶醬結尾"
        ]
      },
      {
        "group": "冷藏與完成",
        "steps": [
          "冷藏至少4小時",
          "上桌前撒上可可粉"
        ]
      }
    ],
    "tags": ["甜點"],
    "source": "https://kthu1031.pixnet.net/blog/posts/8168779730"
  },
  {
    "name": "台式甜不辣",
    "description": "自製魚漿製作的台灣傳統甜不辣，彈牙Q軟",
    "servings": 4,
    "prepTime": 30,
    "cookTime": 20,
    "ingredients": [
      {
        "group": "主要材料",
        "items": [
          {
            "name": "巴沙魚片(Pangasiusfilet)",
            "amount": 360,
            "unit": "g"
          },
          {
            "name": "馬鈴薯澱粉(Aardappelzetmeel)",
            "amount": 5,
            "unit": "tbsp"
          },
          {
            "name": "蛋白",
            "amount": 0.5,
            "unit": "個"
          },
          {
            "name": "冰塊",
            "amount": 2,
            "unit": "顆"
          }
        ]
      },
      {
        "group": "調味料",
        "items": [
          {
            "name": "鹽",
            "amount": 0.75,
            "unit": "tsp"
          },
          {
            "name": "糖",
            "amount": 2,
            "unit": "tsp"
          },
          {
            "name": "白胡椒粉",
            "amount": 0.5,
            "unit": "tsp"
          },
          {
            "name": "大蒜粉",
            "amount": 0.5,
            "unit": "tsp"
          },
          {
            "name": "泡打粉",
            "amount": 0.25,
            "unit": "tsp"
          }
        ]
      }
    ],
    "instructions": [
      {
        "group": "準備魚肉",
        "steps": [
          "巴沙魚片退冰後，用廚房紙巾將水分壓乾至有點乾澀的狀態",
          "切成小塊後，放入冷凍20分鐘"
        ]
      },
      {
        "group": "製作魚漿",
        "steps": [
          "將脫水的魚肉放入料理機中",
          "加入鹽，打至魚肉變黏稠",
          "加入蛋白、糖、白胡椒粉、大蒜粉和冰塊，打至均勻"
        ]
      },
      {
        "group": "加入澱粉",
        "steps": [
          "先加入60g馬鈴薯澱粉混合",
          "觀察質地，如果過稀再補入剩下10g澱粉",
          "混合至適當的黏稠度（像厚漿糊的質地）"
        ]
      },
      {
        "group": "成型與烹飪",
        "steps": [
          "裝入塑膠袋後，塑膠袋剪一個小洞，將魚漿擠出成條狀",
          "160°C熱油中炸到膨脹成型，撈起瀝油",
          "冷卻後可冷凍保存，食用前再炸一次加熱即可"
        ]
      }
    ],
    "tags": ["小吃"]
  }
]
